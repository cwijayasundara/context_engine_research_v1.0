# --- LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=openai:gpt-5.4-mini
# Optional — route through an OpenAI-compatible endpoint. To use Google
# Gemini 3.5 Flash instead, set:
#   OPENAI_API_KEY=<google ai studio key>
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   OPENAI_MODEL=gemini-3.5-flash
OPENAI_BASE_URL=

# --- Agent runtime ---
# "deepagents" uses the Deep Agents 0.6 retrieval runtime.
# "current" or "legacy" keeps the existing src/api/agent_runner.py path.
AGENT_RUNTIME=deepagents
# Deep Agents uses LangChain's Google GenAI model URI by default.
DEEP_AGENT_MODEL=google_genai:gemini-3.5-flash
GOOGLE_API_KEY=

# --- Merchant canonicalizer ---
# "llm"   — cached gpt-5.4-mini classification (cheap, self-extending).
# "regex" — ~50 hand-written rules (zero-cost, deterministic, offline).
# The LLM path falls back to the regex path automatically when OPENAI_API_KEY
# is missing or a call fails, so "llm" is safe as the default.
NORMALIZER=llm
# Where the canonicalizer caches its decisions. One JSON file, ~1 KB per
# unique transaction description; safe to delete (next run rebuilds it).
CANON_CACHE_PATH=data/.canonicalize_cache.json

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j

# --- DeepAgents / LangSmith (optional but recommended) ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=finance-context-engine

# --- Paths ---
STATEMENTS_DIR=data/statements
WIKI_DIR=data/wiki
ONTOLOGY_PATH=data/ontology/finance.yaml

# --- PII ---
# Optional salt for token derivation. Keep secret — rotate if leaked.
PII_TOKEN_SALT=change-me-to-something-random
